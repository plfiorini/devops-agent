    "tsx": "^4.19.4",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@langchain/community": "^0.3.45",
    "@langchain/core": "^0.3.57",
    "@langchain/google-genai": "^0.2.10",
    "@types/yaml": "^1.9.6",
    "dotenv": "^16.5.0",
    "langchain": "^0.3.27",
    "readline": "^1.3.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.32"
  }
