{
	"name": "devops-agent",
	"version": "1.0.0",
	"description": "AI agent for DevOps engineers and cloud architects to automate tasks and manage infrastructure using LLMs.",
	"type": "module",
	"private": true,
	"keywords": [
		"devops",
		"ai",
		"agent",
		"tools",
		"llm",
		"openai",
		"gemini",
		"anthropic"
	],
	"author": "Pier Luigi Fiorini",
	"license": "AGPL-3.0-only",
	"main": "src/index.ts",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "bun build ./src/index.ts --compile --outfile devopsagent",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"format": "biome format",
		"format:write": "biome format --write",
		"lint": "biome lint",
		"test": "bun --test src/**/*.test.ts src/**/*.test.tsx",
		"start": "bun src/index.ts",
		"dev": "bun --watch src/index.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/marked-terminal": "^6.1.1",
		"@types/node": "^24.12.3",
		"@types/react": "^19.2.14",
		"ink-testing-library": "^4.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.54.0",
		"@google/generative-ai": "^0.24.1",
		"ink": "^7.0.2",
		"marked": "^15.0.12",
		"marked-terminal": "^7.3.0",
		"openai": "^5.23.2",
		"react": "^19.2.6",
		"yaml": "^2.9.0",
		"zod": "^3.25.76",
		"zod-to-json-schema": "^3.25.2"
	}
}
