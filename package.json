{
	"name": "devops-agent",
	"version": "1.0.0",
	"description": "AI agent for DevOps engineers and cloud architects to automate tasks and manage infrastructure using LLMs.",
	"type": "module",
	"private": true,
	"keywords": [
		"devops",
		"ai",
		"agent",
		"tools",
		"llm",
		"openai",
		"gemini",
		"anthropic"
	],
	"author": "Pier Luigi Fiorini",
	"license": "AGPL-3.0-only",
	"main": "src/index.tsx",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "bun build ./src/index.tsx --compile --outfile devopsagent",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"format": "biome format",
		"format:write": "biome format --write",
		"lint": "biome lint",
		"test": "vitest run",
		"start": "bun src/index.tsx",
		"dev": "bun --watch src/index.tsx"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"ink-testing-library": "^4.0.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.95.1",
		"@google/generative-ai": "^0.24.1",
		"ink": "^7.0.2",
		"ink-markdown-es": "^1.4.0",
		"ink-scroll-view": "^0.3.7",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"openai": "^6.37.0",
		"react": "^19.2.6",
		"yaml": "^2.9.0",
		"zod": "^4.4.3",
		"zod-to-json-schema": "^3.25.2"
	}
}
